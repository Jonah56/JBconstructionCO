<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>JB Construction | Residential Builder</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      color: #222;
      line-height: 1.6;
    }

    /* HEADER */
    header {
      position: sticky;
      top: 0;
      background: #0f0f0f;
      color: white;
      display: flex;
      justify-content: space-between;
      padding: 15px 25px;
      z-index: 999;
      align-items: center;
    }

    nav a {
      color: white;
      margin: 0 10px;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      color: #ff6600;
    }

    /* HERO */
    .hero {
      height: 92vh;
      background: url('https://images.unsplash.com/photo-1503387762-592deb58ef4e') center/cover;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      text-align: center;
      color: white;
    }

    .overlay {
      position: absolute;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.65);
    }

    .hero-content {
      position: relative;
      max-width: 800px;
      padding: 20px;
    }

    .hero h1 {
      font-size: 48px;
      margin-bottom: 10px;
    }

    .hero p {
      font-size: 18px;
      margin-bottom: 20px;
    }

    .btn {
      padding: 12px 20px;
      background: #ff6600;
      color: white;
      text-decoration: none;
      margin: 5px;
      display: inline-block;
      border-radius: 5px;
      font-weight: bold;
    }

    .btn.secondary {
      background: green;
    }

    /* TRUST BAR */
    .trust {
      background: #ff6600;
      color: white;
      display: flex;
      justify-content: space-around;
      padding: 15px;
      font-weight: bold;
      flex-wrap: wrap;
    }

    /* SECTION */
    section {
      padding: 80px 20px;
      text-align: center;
    }

    h2 {
      font-size: 34px;
      margin-bottom: 20px;
    }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      max-width: 1100px;
      margin: auto;
    }

    .card {
      background: #f4f4f4;
      padding: 20px;
      border-left: 5px solid #ff6600;
      text-align: left;
    }

    /* WHY US */
    .why {
      background: #111;
      color: white;
    }

    .why .card {
      background: #222;
      border-left: 5px solid #ff6600;
    }

    /* PROCESS */
    .process .card {
      background: #fff;
    }

    /* GALLERY */
    .gallery img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 8px;
    }

    /* TESTIMONIALS */
    .testimonial {
      background: #222;
      color: white;
      padding: 20px;
      border-radius: 8px;
    }

    /* CONTACT */
    form {
      max-width: 600px;
      margin: auto;
    }

    input, textarea {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      border: 1px solid #ccc;
    }

    button {
      background: #ff6600;
      color: white;
      padding: 12px;
      border: none;
      width: 100%;
      font-size: 16px;
      cursor: pointer;
    }

    /* FOOTER */
    footer {
      background: #0f0f0f;
      color: white;
      text-align: center;
      padding: 25px;
    }

    /* MOBILE */
    @media (max-width: 768px) {
      .hero h1 {
        font-size: 30px;
      }

      nav {
        display: none;
      }
    }
  </style>
</head>

<body>

<header>
